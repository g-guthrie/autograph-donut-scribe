{
  "name": "@olympus/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "dependencies": {
    "@olympus/protocol": "workspace:*",
    "@olympus/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "wrangler": "^4.76.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "sh -c 'wrangler dev --config wrangler.dev.toml --port ${OLYMPUS_WORKER_PORT:-8787}'",
    "preview": "sh -c 'wrangler dev --config wrangler.toml --port ${OLYMPUS_WORKER_PORT:-8787}'",
    "deploy": "wrangler deploy --config wrangler.toml"
  }
}
